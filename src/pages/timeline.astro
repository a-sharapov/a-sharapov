      content={[
        {
          title: "Сайт под ключ",
          description: "Сайт компании по продаже спортивной одежды и обуви",
          mainSrc: "/folio/2015-2018/kelme/index.png",
          logoSrc: "/folio/2015-2018/kelme/logo.png",
